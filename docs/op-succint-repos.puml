@startuml

package "External Dependencies" {
  [ Kona ] as KonaExternal
  [OP Succinct] as OPSuccintExternal
}

package "Celo" {
  [Celo Kona] as CeloKonaCelo
  [OP Succint] as OPSuccintCelo
}

package "Espresso" {
  [Kona] as KonaEspresso
  [Celo Kona] as CeloKonaEspresso
  [OP Succint] as OPSuccintEspresso
  [OP Integration] as OpIntegration
}


KonaExternal--> CeloKonaCelo: imports

CeloKonaCelo--> OPSuccintCelo : imports
KonaExternal--> OPSuccintExternal : imports
KonaExternal --> OPSuccintCelo: imports

OPSuccintExternal --> OPSuccintCelo: fork
CeloKonaCelo --> CeloKonaEspresso: fork
OPSuccintCelo --> OPSuccintEspresso: fork
KonaExternal --> KonaEspresso: fork

OpIntegration --> OPSuccintEspresso : docker images
KonaEspresso   --> CeloKonaEspresso: imports
CeloKonaEspresso  --> OPSuccintEspresso : imports
KonaEspresso --> OPSuccintEspresso : imports


@enduml
