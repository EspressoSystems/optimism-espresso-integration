#!/usr/bin/env bash
if git diff --cached --name-only | grep -q "^espresso/.env$"; then
  echo "⚠️  WARNING: You updated .env."
  echo "You MUST also update image versions in tee-op-deploy, or create a ticket to do so."
  echo "See .env header for details."
  echo ""
  read -p "Proceed with commit? (yes/no): " yn
  if [ "$yn" != "yes" ]; then
    echo "Commit aborted."
    exit 1
  fi
fi
